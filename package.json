{
  "name": "@iomvpdev/kiro-specs",
  "version": "0.1.0",
  "description": "Reusable Kiro specs templates for AWS CDK projects (lambdas, apigw, platform, step functions)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "kiro-specs": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "templates",
    "partials"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "jest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "handlebars": "^4.7.8",
    "inquirer": "^10.2.2",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.5.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
