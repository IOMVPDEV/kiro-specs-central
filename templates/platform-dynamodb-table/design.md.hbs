## Terraform module block

`terraform/dyn-{{businessDomain}}-{{serviceDomain}}-{{tableName}}/main.tf`

```hcl
module "{{businessDomain}}-{{serviceDomain}}-{{tableName}}" {
  source  = "app.terraform.io/IO-BANKING/cloud-dynamodb/module"
  version = "0.0.17"   # pin to latest certified

  # Identity
  env             = var.env
  project_name    = var.project_name
  business_domain = var.business_domain
  service_domain  = var.service_domain
  version_project = var.version_project
  owner           = var.owner
  journey         = "{{journey}}"
  feature         = "{{feature}}"
  repository      = "${var.project_name}-${var.business_domain}-${var.service_domain}-platform-${var.version_project}"

  # Table
  name         = "{{tableName}}"
  billing_mode = "{{billingMode}}"
  table_class  = "{{tableClass}}"
  hash_key     = "{{hashKeyName}}"
{{#if hasRangeKey}}
  range_key    = "{{rangeKeyName}}"
{{/if}}

  # Security
  dynamo_kms_arn              = data.aws_kms_key.dynamodb.arn
  deletion_protection_enabled = {{deletionProtectionEnabled}}

  # TTL
{{#if ttlEnabled}}
  ttl_attribute_name = "{{ttlAttributeName}}"
{{else}}
  # ttl_attribute_name = null  # TTL disabled
{{/if}}

  # Streams
{{#if streamEnabled}}
  stream_enabled   = true
  stream_view_type = "{{streamViewType}}"
{{else}}
  stream_enabled   = false
{{/if}}

  # Attributes — declare every attribute referenced in a key (base or index)
  attributes = [
    { name = "{{hashKeyName}}", type = "{{hashKeyType}}" },
{{#if hasRangeKey}}
    { name = "{{rangeKeyName}}", type = "{{rangeKeyType}}" },
{{/if}}
    # Add GSI/LSI key attributes below — one entry per attribute name
  ]

{{#if (gt gsiCount "0")}}
  global_secondary_indexes = [
{{#times gsiCount}}
    {
      name            = "by-<attribute>"           # GSI{{index}}: fill in
      hash_key        = "<gsi{{index}}_pk_attr>"
      range_key       = "<gsi{{index}}_sk_attr>"   # set to null if no SK
      projection_type = "ALL"
      read_capacity   = null                       # null = PAY_PER_REQUEST
      write_capacity  = null
    },
{{/times}}
  ]
{{/if}}

{{#if (gt lsiCount "0")}}
  local_secondary_indexes = [
{{#times lsiCount}}
    {
      name            = "by-<attribute>"   # LSI{{index}}: fill in
      range_key       = "<lsi{{index}}_sk_attr>"
      projection_type = "ALL"
    },
{{/times}}
  ]
{{/if}}

{{#if enableResourcePolicy}}
  enable_dynamodb_resource_policy = true
  pci_account_id                  = "{{pciAccountId}}"
{{/if}}

{{#if enableKinesisDestination}}
  enable_kinesis_streaming_destination         = true
  kinesis_stream_arn                           = data.aws_ssm_parameter.kinesis_stream_arn.value
  approximate_creation_date_time_precision     = "MICROSECOND"
{{/if}}
}
```

## Data sources required

`terraform/dyn-{{businessDomain}}-{{serviceDomain}}-{{tableName}}/data.tf`

```hcl
data "aws_kms_key" "dynamodb" {
  key_id = "alias/io-${var.env}-dynamodb"
}
