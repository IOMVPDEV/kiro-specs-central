## Terraform module blocks

`terraform/dynamodb/` — one sub-directory per table following platform repo convention.

{{#each tables}}
### `terraform/dyn-{{../businessDomain}}-{{../serviceDomain}}-{{this.name}}/main.tf`

```hcl
module "{{../businessDomain}}-{{../serviceDomain}}-{{this.name}}" {
  source  = "app.terraform.io/IO-BANKING/cloud-dynamodb/module"
  version = "0.0.17"

  env             = var.env
  project_name    = var.project_name
  business_domain = var.business_domain
  service_domain  = var.service_domain
  version_project = var.version_project
  owner           = var.owner
  journey         = "{{../journey}}"
  feature         = "{{../feature}}"
  repository      = "${var.project_name}-${var.business_domain}-${var.service_domain}-platform-${var.version_project}"

  name         = "{{this.name}}"
  billing_mode = "PAY_PER_REQUEST"
  table_class  = "STANDARD"
  hash_key     = "{{this.hashKey}}"
{{#if this.hasRangeKey}}
  range_key    = "{{this.rangeKey}}"
{{/if}}

  dynamo_kms_arn              = data.aws_kms_key.dynamodb.arn
  deletion_protection_enabled = var.deletion_protection_enabled

{{#if this.ttlEnabled}}
  ttl_attribute_name = "{{this.ttlAttr}}"
{{/if}}

{{#if this.streamEnabled}}
  stream_enabled   = true
  stream_view_type = "{{this.streamViewType}}"
{{else}}
  stream_enabled   = false
{{/if}}

  attributes = [
    { name = "{{this.hashKey}}", type = "{{this.hashKeyType}}" },
{{#if this.hasRangeKey}}
    { name = "{{this.rangeKey}}", type = "{{this.rangeKeyType}}" },
{{/if}}
    # Add GSI key attributes here
  ]

{{#if (gt this.gsiCount "0")}}
  global_secondary_indexes = [
{{#times this.gsiCount}}
    {
      name            = "by-<attribute>"   # GSI{{this.index}}: fill in
      hash_key        = "<gsi{{this.index}}_pk>"
      range_key       = null               # fill in or remove if no SK
      projection_type = "ALL"
      read_capacity   = null
      write_capacity  = null
    },
{{/times}}
  ]
{{/if}}

{{#if this.resourcePolicy}}
  enable_dynamodb_resource_policy = true
  pci_account_id                  = "{{this.pciAccount}}"
{{/if}}
}
```

`terraform/dyn-{{../businessDomain}}-{{../serviceDomain}}-{{this.name}}/data.tf`

```hcl
data "aws_kms_key" "dynamodb" {
  key_id = "alias/io-${var.env}-dynamodb"
}
```

{{/each}}

