{
  "name": "platform-dynamodb-service",
  "description": "Consolidated DynamoDB spec for all tables of a platform service (1-4 tables, single spec/steering)",
  "category": "platform",
  "vars": [
    { "name": "businessDomain",  "prompt": "Business domain (e.g. sale, pay, risk):",          "type": "string",  "required": true },
    { "name": "serviceDomain",   "prompt": "Service domain (e.g. custmr-offer, trx-auth):",    "type": "string",  "required": true },
    { "name": "owner",           "prompt": "Owner / squad name (e.g. trinity):",                "type": "string",  "required": true },
    { "name": "journey",         "prompt": "Journey tag (e.g. checkout, onboarding):",         "type": "string",  "default": "default-journey" },
    { "name": "feature",         "prompt": "Feature tag (e.g. offer-management):",             "type": "string",  "default": "default-feature" },
    { "name": "versionProject",  "prompt": "Project version (e.g. 01):",                       "type": "string",  "default": "01" },
    { "name": "tableCount",      "prompt": "How many DynamoDB tables in this service?",        "type": "select",  "choices": ["1","2","3","4"], "default": "2" },

    { "name": "t1Name",          "prompt": "[Table 1] Short name (e.g. events):",              "type": "string",  "required": true },
    { "name": "t1HashKey",       "prompt": "[Table 1] Hash key name:",                         "type": "string",  "required": true },
    { "name": "t1HashKeyType",   "prompt": "[Table 1] Hash key type:",                         "type": "select",  "choices": ["S","N","B"], "default": "S" },
    { "name": "t1HasRangeKey",   "prompt": "[Table 1] Has range key?",                         "type": "boolean", "default": true },
    { "name": "t1RangeKey",      "prompt": "[Table 1] Range key name:",                        "type": "string",  "when": { "var": "t1HasRangeKey", "equals": true } },
    { "name": "t1RangeKeyType",  "prompt": "[Table 1] Range key type:",                        "type": "select",  "choices": ["S","N","B"], "default": "S", "when": { "var": "t1HasRangeKey", "equals": true } },
    { "name": "t1GsiCount",      "prompt": "[Table 1] Number of GSIs:",                        "type": "select",  "choices": ["0","1","2","3"], "default": "0" },
    { "name": "t1StreamEnabled", "prompt": "[Table 1] Enable DynamoDB Streams?",               "type": "boolean", "default": false },
    { "name": "t1StreamViewType","prompt": "[Table 1] Stream view type:",                       "type": "select",  "choices": ["NEW_AND_OLD_IMAGES","NEW_IMAGE","OLD_IMAGE","KEYS_ONLY"], "default": "NEW_AND_OLD_IMAGES", "when": { "var": "t1StreamEnabled", "equals": true } },
    { "name": "t1TtlEnabled",    "prompt": "[Table 1] Enable TTL?",                            "type": "boolean", "default": true },
    { "name": "t1TtlAttr",       "prompt": "[Table 1] TTL attribute name:",                    "type": "string",  "default": "expireAt", "when": { "var": "t1TtlEnabled", "equals": true } },
    { "name": "t1ResourcePolicy","prompt": "[Table 1] Enable cross-account resource policy (PCI)?", "type": "boolean", "default": false },
    { "name": "t1PciAccount",    "prompt": "[Table 1] PCI account ID:",                        "type": "string",  "when": { "var": "t1ResourcePolicy", "equals": true } },

    { "name": "t2Name",          "prompt": "[Table 2] Short name (e.g. view):",                "type": "string",  "when": { "var": "tableCount", "in": ["2","3","4"] } },
    { "name": "t2HashKey",       "prompt": "[Table 2] Hash key name:",                         "type": "string",  "when": { "var": "tableCount", "in": ["2","3","4"] } },
    { "name": "t2HashKeyType",   "prompt": "[Table 2] Hash key type:",                         "type": "select",  "choices": ["S","N","B"], "default": "S", "when": { "var": "tableCount", "in": ["2","3","4"] } },
    { "name": "t2HasRangeKey",   "prompt": "[Table 2] Has range key?",                         "type": "boolean", "default": true, "when": { "var": "tableCount", "in": ["2","3","4"] } },
    { "name": "t2RangeKey",      "prompt": "[Table 2] Range key name:",                        "type": "string",  "when": { "var": "t2HasRangeKey", "equals": true } },
    { "name": "t2RangeKeyType",  "prompt": "[Table 2] Range key type:",                        "type": "select",  "choices": ["S","N","B"], "default": "S", "when": { "var": "t2HasRangeKey", "equals": true } },
    { "name": "t2GsiCount",      "prompt": "[Table 2] Number of GSIs:",                        "type": "select",  "choices": ["0","1","2","3"], "default": "0", "when": { "var": "tableCount", "in": ["2","3","4"] } },
    { "name": "t2StreamEnabled", "prompt": "[Table 2] Enable DynamoDB Streams?",               "type": "boolean", "default": false, "when": { "var": "tableCount", "in": ["2","3","4"] } },
    { "name": "t2StreamViewType","prompt": "[Table 2] Stream view type:",                       "type": "select",  "choices": ["NEW_AND_OLD_IMAGES","NEW_IMAGE","OLD_IMAGE","KEYS_ONLY"], "default": "NEW_AND_OLD_IMAGES", "when": { "var": "t2StreamEnabled", "equals": true } },
    { "name": "t2TtlEnabled",    "prompt": "[Table 2] Enable TTL?",                            "type": "boolean", "default": true, "when": { "var": "tableCount", "in": ["2","3","4"] } },
    { "name": "t2TtlAttr",       "prompt": "[Table 2] TTL attribute name:",                    "type": "string",  "default": "expireAt", "when": { "var": "t2TtlEnabled", "equals": true } },
    { "name": "t2ResourcePolicy","prompt": "[Table 2] Enable cross-account resource policy (PCI)?", "type": "boolean", "default": false, "when": { "var": "tableCount", "in": ["2","3","4"] } },
    { "name": "t2PciAccount",    "prompt": "[Table 2] PCI account ID:",                        "type": "string",  "when": { "var": "t2ResourcePolicy", "equals": true } },

    { "name": "t3Name",          "prompt": "[Table 3] Short name:",                            "type": "string",  "when": { "var": "tableCount", "in": ["3","4"] } },
    { "name": "t3HashKey",       "prompt": "[Table 3] Hash key name:",                         "type": "string",  "when": { "var": "tableCount", "in": ["3","4"] } },
    { "name": "t3HashKeyType",   "prompt": "[Table 3] Hash key type:",                         "type": "select",  "choices": ["S","N","B"], "default": "S", "when": { "var": "tableCount", "in": ["3","4"] } },
    { "name": "t3HasRangeKey",   "prompt": "[Table 3] Has range key?",                         "type": "boolean", "default": true, "when": { "var": "tableCount", "in": ["3","4"] } },
    { "name": "t3RangeKey",      "prompt": "[Table 3] Range key name:",                        "type": "string",  "when": { "var": "t3HasRangeKey", "equals": true } },
    { "name": "t3RangeKeyType",  "prompt": "[Table 3] Range key type:",                        "type": "select",  "choices": ["S","N","B"], "default": "S", "when": { "var": "t3HasRangeKey", "equals": true } },
    { "name": "t3GsiCount",      "prompt": "[Table 3] Number of GSIs:",                        "type": "select",  "choices": ["0","1","2","3"], "default": "0", "when": { "var": "tableCount", "in": ["3","4"] } },
    { "name": "t3StreamEnabled", "prompt": "[Table 3] Enable DynamoDB Streams?",               "type": "boolean", "default": false, "when": { "var": "tableCount", "in": ["3","4"] } },
    { "name": "t3StreamViewType","prompt": "[Table 3] Stream view type:",                       "type": "select",  "choices": ["NEW_AND_OLD_IMAGES","NEW_IMAGE","OLD_IMAGE","KEYS_ONLY"], "default": "NEW_AND_OLD_IMAGES", "when": { "var": "t3StreamEnabled", "equals": true } },
    { "name": "t3TtlEnabled",    "prompt": "[Table 3] Enable TTL?",                            "type": "boolean", "default": true, "when": { "var": "tableCount", "in": ["3","4"] } },
    { "name": "t3TtlAttr",       "prompt": "[Table 3] TTL attribute name:",                    "type": "string",  "default": "expireAt", "when": { "var": "t3TtlEnabled", "equals": true } },
    { "name": "t3ResourcePolicy","prompt": "[Table 3] Enable cross-account resource policy (PCI)?", "type": "boolean", "default": false, "when": { "var": "tableCount", "in": ["3","4"] } },
    { "name": "t3PciAccount",    "prompt": "[Table 3] PCI account ID:",                        "type": "string",  "when": { "var": "t3ResourcePolicy", "equals": true } },

    { "name": "t4Name",          "prompt": "[Table 4] Short name:",                            "type": "string",  "when": { "var": "tableCount", "in": ["4"] } },
    { "name": "t4HashKey",       "prompt": "[Table 4] Hash key name:",                         "type": "string",  "when": { "var": "tableCount", "in": ["4"] } },
    { "name": "t4HashKeyType",   "prompt": "[Table 4] Hash key type:",                         "type": "select",  "choices": ["S","N","B"], "default": "S", "when": { "var": "tableCount", "in": ["4"] } },
    { "name": "t4HasRangeKey",   "prompt": "[Table 4] Has range key?",                         "type": "boolean", "default": true, "when": { "var": "tableCount", "in": ["4"] } },
    { "name": "t4RangeKey",      "prompt": "[Table 4] Range key name:",                        "type": "string",  "when": { "var": "t4HasRangeKey", "equals": true } },
    { "name": "t4RangeKeyType",  "prompt": "[Table 4] Range key type:",                        "type": "select",  "choices": ["S","N","B"], "default": "S", "when": { "var": "t4HasRangeKey", "equals": true } },
    { "name": "t4GsiCount",      "prompt": "[Table 4] Number of GSIs:",                        "type": "select",  "choices": ["0","1","2","3"], "default": "0", "when": { "var": "tableCount", "in": ["4"] } },
    { "name": "t4StreamEnabled", "prompt": "[Table 4] Enable DynamoDB Streams?",               "type": "boolean", "default": false, "when": { "var": "tableCount", "in": ["4"] } },
    { "name": "t4StreamViewType","prompt": "[Table 4] Stream view type:",                       "type": "select",  "choices": ["NEW_AND_OLD_IMAGES","NEW_IMAGE","OLD_IMAGE","KEYS_ONLY"], "default": "NEW_AND_OLD_IMAGES", "when": { "var": "t4StreamEnabled", "equals": true } },
    { "name": "t4TtlEnabled",    "prompt": "[Table 4] Enable TTL?",                            "type": "boolean", "default": true, "when": { "var": "tableCount", "in": ["4"] } },
    { "name": "t4TtlAttr",       "prompt": "[Table 4] TTL attribute name:",                    "type": "string",  "default": "expireAt", "when": { "var": "t4TtlEnabled", "equals": true } },
    { "name": "t4ResourcePolicy","prompt": "[Table 4] Enable cross-account resource policy (PCI)?", "type": "boolean", "default": false, "when": { "var": "tableCount", "in": ["4"] } },
    { "name": "t4PciAccount",    "prompt": "[Table 4] PCI account ID:",                        "type": "string",  "when": { "var": "t4ResourcePolicy", "equals": true } }
  ],
  "files": [
    { "src": "requirements.md.hbs", "dest": ".kiro/specs/dynamodb/requirements.md" },
    { "src": "design.md.hbs",       "dest": ".kiro/specs/dynamodb/design.md" },
    { "src": "tasks.md.hbs",        "dest": ".kiro/specs/dynamodb/tasks.md" },
    { "src": "steering.md.hbs",     "dest": ".kiro/steering/dynamodb.md" }
  ]
}
